# Option A: individual settings (recommended)
DB_USER=srihari
DB_PASSWORD=srihari
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geovault

# Option B: single URL (overrides Option A if set)
# DATABASE_URL=postgresql://user:pass@localhost:5432/geovault

SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated browser origins for the React dev server (Vite default :5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
