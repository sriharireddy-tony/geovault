# Option A: individual settings (recommended)
DB_USER=srihari
DB_PASSWORD=srihari
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geovault

# Option B: single URL (overrides Option A if set)
# DATABASE_URL=postgresql://user:pass@localhost:5432/geovault

SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech

PROJECT_EXPORT_DIR=C:\Users\srihari.p\Desktop\YT\Projects

# ── AI Providers ──────────────────────────────────────────────
# Active: ollama (free/local) | openai | gemini
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Ollama — install from https://ollama.com then:
#   ollama pull llama3.1:8b
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI — set LLM_PROVIDER=openai and EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Gemini — set LLM_PROVIDER=gemini and EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=models/text-embedding-004

CHROMA_PERSIST_DIR=chroma_data
CHROMA_COLLECTION=geovault_knowledge
# auto = prefer Chroma, fall back to local if grpc blocked
VECTOR_STORE=auto

# Queue (optional)
USE_REDIS_QUEUE=false
REDIS_URL=redis://127.0.0.1:6379

RAG_TOP_K=8
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_HISTORY_LIMIT=20

# LangSmith observability (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=geovault-knowledge

ENABLE_GUARDRAILS=true
ENABLE_EVALUATION=true
GUARDRAILS_BLOCK_ON_FAIL=true
